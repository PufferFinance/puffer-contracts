#   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-
#  / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \
# `-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'

# By default, the examples support both mnemonic-based and private key-based authentication
#
# For wiring is not necessary to set any of these values, since all is owned by multisigs
# You don't need to set both of these values, just pick the one that you prefer and set that one
MNEMONIC=
PRIVATE_KEY=

# RPC URLs (optional - defaults are provided in chain configs)
ETHEREUM_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
HYPERLIQUID_RPC_URL=
LINEA_RPC_URL=
MEGAETH_RPC_URL=
MONAD_RPC_URL=
TAC_RPC_URL=

# Block Explorer API Keys (optional - for contract verification)
ETHERSCAN_API_KEY=
BASE_EXPLORER_API_KEY=
BSC_EXPLORER_API_KEY=
HYPERLIQUID_EXPLORER_API_KEY=
LINEA_EXPLORER_API_KEY=
MEGAETH_EXPLORER_API_KEY=
MONAD_EXPLORER_API_KEY=
TAC_EXPLORER_API_KEY=

# Legacy (kept for backwards compatibility)
RPC_URL_ETHEREUM=
RPC_URL_BSC=
TOKEN_ADDRESS=
